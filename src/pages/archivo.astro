---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { archiveItems, categoryLabels } from "../lib/archive.ts";

const filters: ("todo" | "destacado" | "web" | "grafico" | "fotografia")[] = [
  "todo",
  "destacado",
  "web",
  "grafico",
  "fotografia",
];
---

<Base
  title="Archivo · Trabajos anteriores — Fabri Web"
  description="Archivo histórico de trabajos en diseño web, gráfico y fotografía."
>
  <Nav />

  <main class="pt-32 pb-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-12">
        <a href="/" class="inline-flex items-center gap-1.5 text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition mb-6">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Volver al inicio
        </a>
        <p class="text-sm uppercase tracking-widest text-[var(--color-accent)] font-semibold">Archivo</p>
        <h1 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight gradient-text">Trabajos anteriores</h1>
        <p class="mt-4 text-[var(--color-fg-muted)] max-w-2xl">
          Una selección de trabajos como freelance en diseño web, gráfico y fotografía. Material histórico, conservado por cariño a lo hecho.
        </p>
      </div>

      <div class="flex flex-wrap gap-2 mb-10 sticky top-16 bg-[var(--color-bg)]/80 backdrop-blur py-3 z-40 -mx-6 px-6 border-y border-[var(--color-border)]/40">
        {filters.map((f) => (
          <button
            type="button"
            data-filter={f}
            class:list={[
              "filter-btn rounded-full border px-4 py-1.5 text-sm transition",
              f === "todo"
                ? "border-[var(--color-accent)] bg-[var(--color-accent)]/10 text-[var(--color-accent)]"
                : "border-[var(--color-border)] bg-[var(--color-surface)]/40 text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-surface)]",
            ]}
          >
            {categoryLabels[f]}
          </button>
        ))}
      </div>

      <div id="grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {archiveItems.map((item) => (
          <button
            type="button"
            class="archive-item group relative rounded-2xl overflow-hidden border border-[var(--color-border)] bg-[var(--color-surface)]/40 aspect-[4/3]"
            data-categories={[item.featured ? "destacado" : "", ...item.categories].filter(Boolean).join(" ")}
            data-full={item.full}
            data-title={item.title}
          >
            <img
              src={item.thumb}
              alt={item.title}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition flex items-end p-5">
              <div class="text-left">
                <div class="font-semibold tracking-tight">{item.title}</div>
                <div class="mt-1 text-xs uppercase tracking-wider text-[var(--color-fg-muted)]">
                  {item.categories.map((c) => categoryLabels[c]).join(" · ")}
                </div>
              </div>
            </div>
          </button>
        ))}
      </div>
    </div>
  </main>

  <dialog id="lightbox" class="bg-transparent p-0 m-0 max-w-none w-full h-full backdrop:bg-black/90">
    <div class="fixed inset-0 flex items-start justify-center p-4 md:p-10 overflow-auto">
      <button
        type="button"
        id="lightbox-close"
        class="fixed top-4 right-4 z-10 rounded-full bg-[var(--color-surface)] border border-[var(--color-border)] w-10 h-10 flex items-center justify-center text-[var(--color-fg)] hover:bg-[var(--color-bg-soft)]"
        aria-label="Cerrar"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <img id="lightbox-img" src="" alt="" class="max-w-5xl w-full h-auto rounded-xl shadow-2xl" />
    </div>
  </dialog>

  <Footer />
</Base>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items = document.querySelectorAll<HTMLElement>(".archive-item");
  const dialog = document.getElementById("lightbox") as HTMLDialogElement;
  const dialogImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const closeBtn = document.getElementById("lightbox-close");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;
      buttons.forEach((b) => {
        b.classList.remove("border-[var(--color-accent)]", "bg-[var(--color-accent)]/10", "text-[var(--color-accent)]");
        b.classList.add("border-[var(--color-border)]", "bg-[var(--color-surface)]/40", "text-[var(--color-fg-muted)]");
      });
      btn.classList.remove("border-[var(--color-border)]", "bg-[var(--color-surface)]/40", "text-[var(--color-fg-muted)]");
      btn.classList.add("border-[var(--color-accent)]", "bg-[var(--color-accent)]/10", "text-[var(--color-accent)]");

      items.forEach((item) => {
        const cats = (item.dataset.categories || "").split(" ");
        const show = filter === "todo" || cats.includes(filter);
        (item as HTMLElement).style.display = show ? "" : "none";
      });
    });
  });

  items.forEach((item) => {
    item.addEventListener("click", () => {
      dialogImg.src = item.dataset.full!;
      dialogImg.alt = item.dataset.title!;
      dialog.showModal();
    });
  });

  closeBtn?.addEventListener("click", () => dialog.close());
  dialog.addEventListener("click", (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>
