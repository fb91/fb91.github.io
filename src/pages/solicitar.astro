---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
import Wizard from "../components/wizard/Wizard.tsx";
---

<Base
  title="Solicitá tu sitio web — Fabri Web"
  description="Completá el formulario y te contacto en menos de 24hs."
>
  <header class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-[var(--color-bg)]/70 border-b border-[var(--color-border)]/60">
    <nav class="mx-auto max-w-6xl px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold tracking-tight">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-[var(--color-accent)] glow"></span>
        <span>Fabri<span class="text-[var(--color-accent)]">.</span>web</span>
      </a>
      <a href="/" class="text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition">
        ← Volver
      </a>
    </nav>
  </header>

  <main class="pt-24 min-h-dvh">
    <div class="mx-auto max-w-2xl px-6 pt-10 text-center">
      <p class="text-sm uppercase tracking-widest text-[var(--color-accent)] font-semibold">Solicitud</p>
      <h1 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight">Hagamos tu sitio</h1>
      <p class="mt-3 text-[var(--color-fg-muted)]">Te toma 5 minutos. Te respondo en menos de 24hs.</p>
    </div>

    <Wizard client:load />
  </main>

  <Footer />
</Base>
