---

<section class="py-24 md:py-32 border-t border-[var(--color-border)]/60 relative overflow-hidden">
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse at center, rgba(249,115,22,0.12) 0%, transparent 60%);"
  >
  </div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight">
      ¿Listo para tener tu sitio online <span class="text-[var(--color-accent)]">mañana</span>?
    </h2>
    <p class="mt-4 text-[var(--color-fg-muted)] max-w-2xl mx-auto text-lg">
      Completá el formulario en 5 minutos y te contacto en menos de 24hs.
    </p>
    <a
      href="/solicitar"
      class="mt-10 inline-flex items-center gap-2 rounded-full bg-[var(--color-accent)] text-[var(--color-accent-fg)] px-8 py-4 text-base font-semibold hover:bg-[var(--color-accent-soft)] transition glow"
    >
      Solicitá tu sitio
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>
