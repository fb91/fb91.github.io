---
import { recentWorks } from "../lib/works";
---

<section id="trabajos" class="py-24 md:py-32 border-t border-[var(--color-border)]/60">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div>
        <p class="text-sm uppercase tracking-widest text-[var(--color-accent)] font-semibold">Trabajos recientes</p>
        <h2 class="mt-3 text-3xl md:text-5xl font-bold tracking-tight">
          Construido con esta misma metodología
        </h2>
      </div>
      <p class="text-[var(--color-fg-muted)] max-w-md">
        Cada sitio es a medida, optimizado y entregado en menos de 24hs.
      </p>
    </div>

    {recentWorks.length === 0 ? (
      <div class="rounded-3xl border border-dashed border-[var(--color-border)] bg-[var(--color-surface)]/30 p-16 text-center">
        <div class="mx-auto w-12 h-12 rounded-full bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/30 flex items-center justify-center mb-4">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)]"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
        </div>
        <h3 class="text-xl font-semibold">Pronto vamos a llenar este espacio</h3>
        <p class="mt-2 text-[var(--color-fg-muted)] max-w-md mx-auto">
          Estoy arrancando con esta nueva propuesta. ¿Querés ser uno de los primeros casos? Te hago un descuento.
        </p>
        <a
          href="/solicitar"
          class="mt-6 inline-flex items-center gap-2 rounded-full bg-[var(--color-accent)] text-[var(--color-accent-fg)] px-5 py-2.5 text-sm font-semibold hover:bg-[var(--color-accent-soft)] transition"
        >
          Solicitar mi sitio
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentWorks.map((w) => (
          <a href={w.url} target="_blank" rel="noopener" class="group rounded-2xl overflow-hidden border border-[var(--color-border)] bg-[var(--color-surface)]/40 hover:bg-[var(--color-surface)] transition">
            <div class="aspect-[16/10] overflow-hidden bg-[var(--color-bg-soft)]">
              <img src={w.image} alt={w.name} class="w-full h-full object-cover group-hover:scale-105 transition duration-700" loading="lazy" />
            </div>
            <div class="p-5">
              <div class="text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">{w.industry}</div>
              <div class="mt-1 font-semibold tracking-tight">{w.name}</div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>
