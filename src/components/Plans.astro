---
const plans = [
  {
    name: "Sitio expositivo",
    tagline: "Ideal para presentar tu negocio",
    priceFrom: "Desde $80.000",
    cta: "Quiero este plan",
    href: "/solicitar?plan=estatico",
    features: [
      "Diseño moderno a medida",
      "Optimizado para Google (SEO local)",
      "Velocidad de carga 100/100",
      "Adaptado a celular y tablet",
      "WhatsApp directo y mapa",
      "Hospedaje incluido",
    ],
    highlight: false,
  },
  {
    name: "Sitio con panel administrativo",
    tagline: "Actualizá vos mismo el contenido",
    priceFrom: "Desde $140.000",
    cta: "Quiero este plan",
    href: "/solicitar?plan=cms",
    features: [
      "Todo lo del plan expositivo",
      "Panel para editar textos e imágenes",
      "Cargá servicios, precios y reseñas",
      "Cambios sin tocar código",
      "Soporte de imágenes optimizadas",
      "Capacitación de uso incluida",
    ],
    highlight: true,
  },
];
---

<section id="planes" class="py-24 md:py-32 border-t border-[var(--color-border)]/60">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-16">
      <p class="text-sm uppercase tracking-widest text-[var(--color-accent)] font-semibold">Planes</p>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold tracking-tight">
        Elegí el que se adapta a tu negocio
      </h2>
      <p class="mt-4 text-[var(--color-fg-muted)] max-w-2xl mx-auto">
        Dos opciones simples. Sin sorpresas, sin contratos largos. Pagás un setup y un mantenimiento mensual bajo.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 md:gap-8">
      {plans.map((p) => (
        <div
          class:list={[
            "relative rounded-3xl p-8 md:p-10 border bg-[var(--color-surface)]/40 backdrop-blur",
            p.highlight
              ? "border-[var(--color-accent)]/40 ring-1 ring-[var(--color-accent)]/30"
              : "border-[var(--color-border)]",
          ]}
        >
          {p.highlight && (
            <div class="absolute -top-3 right-6 rounded-full bg-[var(--color-accent)] text-[var(--color-accent-fg)] px-3 py-1 text-xs font-bold uppercase tracking-wider">
              Más completo
            </div>
          )}

          <h3 class="text-2xl font-bold tracking-tight">{p.name}</h3>
          <p class="mt-1 text-sm text-[var(--color-fg-muted)]">{p.tagline}</p>

          <div class="mt-6 flex items-baseline gap-2">
            <span class="text-4xl font-extrabold">{p.priceFrom}</span>
          </div>
          <p class="mt-1 text-xs text-[var(--color-fg-subtle)]">+ mantenimiento mensual bajo</p>

          <ul class="mt-8 space-y-3">
            {p.features.map((f) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="mt-0.5 shrink-0 text-[var(--color-accent)]" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>

          <a
            href={p.href}
            class:list={[
              "mt-10 inline-flex w-full items-center justify-center gap-2 rounded-full px-6 py-3.5 text-sm font-semibold transition",
              p.highlight
                ? "bg-[var(--color-accent)] text-[var(--color-accent-fg)] hover:bg-[var(--color-accent-soft)]"
                : "border border-[var(--color-border)] bg-[var(--color-bg-soft)] hover:bg-[var(--color-surface)]",
            ]}
          >
            {p.cta}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>

    <p class="mt-10 text-center text-sm text-[var(--color-fg-subtle)]">
      ¿No estás seguro qué plan te conviene? Solicitalo igual y lo charlamos sin compromiso.
    </p>
  </div>
</section>
